{
  "name": "nextjs-typescript-boilerplate",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev & yarn watch:typed-scss",
    "build": "next build",
    "start": "next start",
    "watch:typed-scss": "typed-scss-modules src --watch --exportType default --nameFormat camel",
    "lint": "eslint \"**/*.{ts,tsx}\"",
    "format": "prettier --write \"*/**/*.{js,ts,tsx}\"",
    "lint:fix": "yarn lint --fix && yarn format"
  },
  "dependencies": {
    "next": "12.1.5",
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "typed-scss-modules": "^6.2.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^12.1.5",
    "@types/node": "17.0.25",
    "@types/react": "18.0.5",
    "@types/react-dom": "18.0.1",
    "@typescript-eslint/eslint-plugin": "^5.20.0",
    "@typescript-eslint/parser": "^5.20.0",
    "eslint": "^8.13.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^16.2.0",
    "eslint-config-next": "12.1.5",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.29.4",
    "eslint-plugin-react-hooks": "^4.4.0",
    "prettier": "^2.6.2",
    "sass": "^1.50.1",
    "typescript": "4.6.3"
  }
}
